# OpenRouter API key — server-side only, never exposed to the client.
# Get one at https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Model slugs (OpenRouter catalog format: provider/model-slug).
# Free tier generation model.
DEFAULT_MODEL=deepseek/deepseek-v4-flash

# Pro tier generation model.
PRO_MODEL=z-ai/glm-5.2

# Used when the primary model's provider is down or errors out.
FALLBACK_MODEL=google/gemini-2.5-flash-lite
