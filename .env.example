# OpenRouter API key — server-side only, never exposed to the client.
# Get one at https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Model slugs (OpenRouter catalog format: provider/model-slug).
# Free tier generation model.
DEFAULT_MODEL=deepseek/deepseek-v4-flash

# Pro tier generation model.
PRO_MODEL=z-ai/glm-5.2

# Used when the primary model's provider is down or errors out.
FALLBACK_MODEL=google/gemini-2.5-flash-lite

# Optional — error tracking (Milestone 5). Leave both unset and Sentry is a
# complete no-op (see instrumentation.ts / instrumentation-client.ts).
# Get a DSN at https://sentry.io (free tier). NEXT_PUBLIC_SENTRY_DSN is
# exposed to the browser by design — Sentry DSNs aren't secret.
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=

# Optional — the deployed site's canonical URL, used for OG image/metadata
# absolute URLs (Milestone 5). Defaults to a placeholder if unset.
NEXT_PUBLIC_SITE_URL=
